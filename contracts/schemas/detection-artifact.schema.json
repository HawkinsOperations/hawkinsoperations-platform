{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Detection Artifact Contract",
  "type": "object",
  "required": [
    "detection_id",
    "repository",
    "commit",
    "artifact_paths"
  ],
  "properties": {
    "detection_id": { "type": "string" },
    "repository": { "type": "string" },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "artifact_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "attack_mapping_path": { "type": "string" },
    "manifest_path": { "type": "string" }
  },
  "additionalProperties": true
}
