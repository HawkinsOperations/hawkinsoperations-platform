  "$id": "https://github.com/HawkinsOperations/hawkinsoperations-platform/contracts/schemas/ho-det-001-runtime-contract.schema.json",
  "title": "HO-DET-001 Runtime Contract Enforcement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_id",
    "contract_type",
    "detection_id",
    "proof_ceiling",
    "public_safe_status",
    "promotion_status",
