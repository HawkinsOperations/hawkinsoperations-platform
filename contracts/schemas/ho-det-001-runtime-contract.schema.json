    "ai_may_close": {
      "type": "boolean",
      "const": false
    },
    "human_review_required": {
      "type": "boolean",
      "const": true
    },
    "allowed_claims": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": [
          "validation PR #18 clone-runnable proof pack merged",
          "platform runtime contract enforcement exists",
          "public proof ceiling remains CONTROLLED_TEST_VALIDATED",
          "runtime-active and signal-observed remain blocked"
