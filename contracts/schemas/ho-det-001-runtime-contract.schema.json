    "validation_result_ref": {
      "const": "hawkinsoperations-validation/reports/ho-det-001/validation-result.json"
    },
    "case_packet_ref": {
      "const": "hawkinsoperations-validation/validation/successor/ho-det-001/case-packet.json"
