    },
    "public_safe_runtime_proof": {
      "type": "boolean",
      "const": false
    },
    "ai_decided_disposition": {
      "type": "boolean",
      "const": false
    },
    "ai_may_approve": {
      "type": "boolean",
      "const": false
    },
    "ai_may_promote": {
      "type": "boolean",
      "const": false
