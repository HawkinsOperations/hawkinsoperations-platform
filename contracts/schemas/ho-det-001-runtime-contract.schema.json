    },
    "blocked_claims": {
      "type": "array",
      "minItems": 12,
      "uniqueItems": true,
      "items": {
        "enum": [
          "runtime-active",
          "signal-observed",
          "public-safe runtime proof",
          "production-ready",
          "fleet-wide",
          "Splunk-proven Runtime Signal 001",
