{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HawkinsOperations/hawkinsoperations-platform/contracts/schemas/soar-case-packet-v0.schema.json",
  "title": "SOAR Case Packet v0 Analyst Support Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_type",
    "contract_version",
    "workflow_model",
    "claim_ceiling",
    "detection_id",
    "technique_id",
    "tactic_id",
    "alert_summary",
    "source_event_refs",
    "enrichment",
    "entities",
    "analyst_checklist",
    "recommended_next_questions",
    "response_gates",
    "blocked_actions",
    "automation_metrics",
    "ai_support_summary",
    "human_review_required",
    "ai_decided_disposition",
    "recommended_disposition",
    "public_safe",
    "claim_boundary",
    "does_not_prove"
  ],
  "properties": {
    "packet_id": {
      "const": "SOAR-CASE-PACKET-V0-SAMPLE-001"
    },
    "packet_type": {
      "const": "soar_style_analyst_support_case_packet"
    },
    "contract_version": {
      "const": "soar-case-packet-v0"
    },
    "workflow_model": {
      "const": "deterministic_analyst_support_only"
    },
    "claim_ceiling": {
      "const": "SOAR_STYLE_ANALYST_SUPPORT_CONTRACT_WITH_DETERMINISTIC_VALIDATION"
    },
    "detection_id": {
      "type": "string",
      "minLength": 1
    },
    "technique_id": {
      "type": "string",
      "minLength": 1
    },
    "tactic_id": {
      "type": "string",
      "minLength": 1
    },
    "alert_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "severity",
        "summary",
        "supported_scope",
        "validation_basis"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "informational",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "supported_scope": {
          "const": "controlled analyst-support workflow modeling only"
        },
        "validation_basis": {
          "const": "committed sanitized sample plus deterministic verifier"
        }
      }
    },
    "source_event_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ref_id",
          "source_type",
          "sanitized",
          "raw_event_included",
          "reference"
        ],
        "properties": {
          "ref_id": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "minLength": 1
          },
          "sanitized": {
            "type": "boolean",
            "const": true
          },
          "raw_event_included": {
            "type": "boolean",
            "const": false
          },
          "reference": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "enrichment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detection_context",
        "validation_context",
        "known_false_positive_notes",
        "risk_indicators",
        "missing_context"
      ],
      "properties": {
        "detection_context": {
          "type": "string",
          "minLength": 1
        },
        "validation_context": {
          "type": "string",
          "minLength": 1
        },
        "known_false_positive_notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_indicators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "missing_context": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "entities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user",
        "host",
        "process",
        "parent_process",
        "source",
        "destination",
        "risk_indicators"
      ],
      "properties": {
        "user": {
          "$ref": "#/$defs/entity"
        },
        "host": {
          "$ref": "#/$defs/entity"
        },
        "process": {
          "$ref": "#/$defs/process_entity"
        },
        "parent_process": {
          "$ref": "#/$defs/process_entity"
        },
        "source": {
          "$ref": "#/$defs/entity"
        },
        "destination": {
          "$ref": "#/$defs/entity"
        },
        "risk_indicators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "analyst_checklist": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "question",
          "required_before_action"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "required_before_action": {
            "type": "boolean",
            "const": true
          }
        }
      }
    },
    "recommended_next_questions": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "response_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "containment",
        "closure",
        "suppression",
        "account_disable",
        "public_proof"
      ],
      "properties": {
        "containment": {
          "$ref": "#/$defs/blocked_gate"
        },
        "closure": {
          "$ref": "#/$defs/blocked_gate"
        },
        "suppression": {
          "$ref": "#/$defs/blocked_gate"
        },
        "account_disable": {
          "$ref": "#/$defs/blocked_gate"
        },
        "public_proof": {
          "$ref": "#/$defs/blocked_gate"
        }
      }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "contain host",
          "close case",
          "suppress detection",
          "disable account",
          "isolate endpoint",
          "declare compromise",
          "mark malicious",
          "approve public proof"
        ]
      }
    },
    "automation_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checklist_steps",
        "blocked_action_count",
        "human_gate_count",
        "sanitized_event_ref_count",
        "deterministic_validation"
      ],
      "properties": {
        "checklist_steps": {
          "type": "integer",
          "minimum": 4
        },
        "blocked_action_count": {
          "const": 8
        },
        "human_gate_count": {
          "type": "integer",
          "minimum": 5
        },
        "sanitized_event_ref_count": {
          "type": "integer",
          "minimum": 1
        },
        "deterministic_validation": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "ai_support_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "allowed_outputs",
        "authority_boundary"
      ],
      "properties": {
        "mode": {
          "const": "AI_SUPPORT_ONLY"
        },
        "allowed_outputs": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "summarize sanitized facts",
              "identify missing context",
              "draft questions for human review",
              "map relevant fields to checklist steps"
            ]
          }
        },
        "authority_boundary": {
          "const": "AI output may support review, but it cannot decide disposition, execute response, approve proof, or close the case."
        }
      }
    },
    "human_review_required": {
      "type": "boolean",
      "const": true
    },
    "ai_decided_disposition": {
      "type": "boolean",
      "const": false
    },
    "recommended_disposition": {
      "type": "null"
    },
    "public_safe": {
      "type": "boolean",
      "const": false
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported_claim",
        "not_supported",
        "public_claim_allowed"
      ],
      "properties": {
        "supported_claim": {
          "const": "SOAR-style analyst-support case packet contract with deterministic validation."
        },
        "not_supported": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "public_claim_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "does_not_prove": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "sanitized",
        "raw_value_included"
      ],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "sanitized": {
          "type": "boolean",
          "const": true
        },
        "raw_value_included": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "process_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image",
        "command_line_features",
        "sanitized",
        "raw_command_line_included"
      ],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1
        },
        "command_line_features": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sanitized": {
          "type": "boolean",
          "const": true
        },
        "raw_command_line_included": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "blocked_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requires_human_approval",
        "executed"
      ],
      "properties": {
        "status": {
          "const": "blocked"
        },
        "requires_human_approval": {
          "type": "boolean",
          "const": true
        },
        "executed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
