{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hoxline ProofCard Draft v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "detection_id",
    "execution_id",
    "evidence_graph_hash",
    "promotion_hash",
    "runtime_truth_class",
    "proof_ceiling",
    "public_safe_status",
    "allowed_claims",
    "blocked_claims",
    "missing_evidence",
    "reviewer_next_actions",
    "human_review_required",
    "public_proof_promoted",
    "ledger_mutated",
    "schedule_enabled",
    "proofcard_draft_hash"
  ],
  "properties": {
    "schema_version": { "const": "hoxline-proofcard-draft-v0" },
    "detection_id": { "const": "HO-DET-001" },
    "execution_id": { "type": "string" },
    "evidence_graph_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "promotion_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "runtime_truth_class": { "const": "PRIVATE_CONTROLLED_RUNTIME_PROOF" },
    "proof_ceiling": { "const": "PRIVATE_CONTROLLED_RUNTIME_PROOF" },
    "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
    "allowed_claims": { "type": "array", "items": { "type": "string" } },
    "blocked_claims": { "type": "array", "items": { "type": "string" } },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "reviewer_next_actions": { "type": "array", "items": { "type": "string" } },
    "human_review_required": { "const": true },
    "public_proof_promoted": { "const": false },
    "ledger_mutated": { "const": false },
    "schedule_enabled": { "const": false },
    "proofcard_draft_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
