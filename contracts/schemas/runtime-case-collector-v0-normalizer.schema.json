{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HawkinsOperations/hawkinsoperations-platform/contracts/schemas/runtime-case-collector-v0-normalizer.schema.json",
  "title": "Runtime Case Collector v0 Normalizer Append Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_utc",
    "source_windows_candidate_count",
    "source_linux_candidate_count",
    "normalized_candidate_count",
    "duplicate_count",
    "append_ready_count",
    "blocked_count",
    "candidates",
    "rejected_duplicates",
    "append_gate_status",
    "append_requires_human_approval",
    "lifetime_ledger_mutated",
    "proof_ceiling",
    "public_safe_status",
    "boundary_summary"
  ],
  "properties": {
    "schema_version": { "const": "runtime-case-collector-v0-normalizer" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "source_windows_candidate_count": { "type": "integer", "minimum": 0 },
    "source_linux_candidate_count": { "type": "integer", "minimum": 0 },
    "normalized_candidate_count": { "type": "integer", "minimum": 0 },
    "duplicate_count": { "type": "integer", "minimum": 0 },
    "append_ready_count": { "type": "integer", "minimum": 0 },
    "blocked_count": { "type": "integer", "minimum": 0 },
    "append_gate_status": { "const": "PLAN_ONLY_APPEND_APPROVAL_REQUIRED" },
    "append_requires_human_approval": { "type": "boolean", "const": true },
    "lifetime_ledger_mutated": { "type": "boolean", "const": false },
    "governed_cases_appended": { "type": "boolean", "const": false },
    "proof_ceiling": {
      "const": "RUNTIME_CASE_COLLECTOR_V0_NORMALIZER_APPEND_GATE_EXISTS_NO_LEDGER_MUTATION_UNLESS_APPEND_APPROVED"
    },
    "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
    "boundary_summary": { "type": "string", "minLength": 1 },
    "rejected_duplicates": { "type": "array" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "normalized_candidate_version",
          "normalized_candidate_id",
          "normalized_candidate_hash",
          "source_candidate_id",
          "source_candidate_hash",
          "source_collector_lane",
          "source_collector_version",
          "source_collector_run_id",
          "source_system",
          "detection_id",
          "detection_family",
          "observed_time_utc",
          "sanitized_event_fingerprint",
          "source_receipt_refs",
          "source_receipt_refs_hash",
          "candidate_payload_hash",
          "normalized_payload_hash",
          "proof_ceiling",
          "public_safe_status",
          "runtime_truth_status",
          "signal_truth_status",
          "case_status",
          "append_status",
          "append_blocked_reason",
          "triage_status",
          "disposition_status",
          "ai_support_mode",
          "ai_decided_disposition",
          "human_review_required",
          "deterministic_close_eligible",
          "deterministic_close_blocked",
          "case_closed",
          "append_to_lifetime_ledger",
          "blocked_claims",
          "notes_boundary"
        ],
        "properties": {
          "normalized_candidate_version": { "const": "runtime-case-collector-v0-normalizer" },
          "normalized_candidate_id": { "type": "string", "pattern": "^rccv0-normalized-[0-9a-f]{16}$" },
          "normalized_candidate_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "source_candidate_id": { "type": "string", "minLength": 1 },
          "source_candidate_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "source_collector_lane": { "enum": ["windows", "linux"] },
          "source_collector_version": {
            "enum": ["runtime-case-collector-v0-windows", "runtime-case-collector-v0-linux"]
          },
          "source_collector_run_id": { "type": "string", "minLength": 1 },
          "source_system": { "type": "string", "minLength": 1 },
          "detection_id": { "type": "string", "minLength": 1 },
          "detection_family": { "type": "string", "minLength": 1 },
          "observed_time_utc": { "type": "string", "minLength": 1 },
          "sanitized_event_fingerprint": { "type": "string", "minLength": 1 },
          "source_receipt_refs": { "type": "array", "minItems": 1 },
          "source_receipt_refs_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "candidate_payload_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "normalized_payload_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "proof_ceiling": {
            "const": "RUNTIME_CASE_COLLECTOR_V0_NORMALIZER_APPEND_GATE_EXISTS_NO_LEDGER_MUTATION_UNLESS_APPEND_APPROVED"
          },
          "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
          "runtime_truth_status": { "type": "string", "minLength": 1 },
          "signal_truth_status": { "type": "string", "minLength": 1 },
          "case_status": { "const": "RUNTIME_CANDIDATE_ONLY" },
          "append_status": { "const": "APPEND_READY_REQUIRES_EXACT_APPROVAL" },
          "append_blocked_reason": { "const": "APPEND_APPROVAL_REQUIRED" },
          "triage_status": { "const": "HUMAN_REVIEW_REQUIRED" },
          "disposition_status": { "const": "NO_DISPOSITION" },
          "ai_support_mode": { "const": "AI_SUPPORT_ONLY" },
          "ai_decided_disposition": { "type": "boolean", "const": false },
          "human_review_required": { "type": "boolean", "const": true },
          "deterministic_close_eligible": { "type": "boolean", "const": false },
          "deterministic_close_blocked": { "type": "boolean", "const": true },
          "case_closed": { "type": "boolean", "const": false },
          "append_to_lifetime_ledger": { "type": "boolean", "const": false },
          "blocked_claims": { "type": "array", "minItems": 1 },
          "notes_boundary": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
