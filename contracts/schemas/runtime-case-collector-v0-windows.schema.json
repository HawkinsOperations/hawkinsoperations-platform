{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HawkinsOperations/hawkinsoperations-platform/contracts/schemas/runtime-case-collector-v0-windows.schema.json",
  "title": "Runtime Case Collector v0 Windows Candidate Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "collector_version",
    "collector_lane",
    "collector_run_id",
    "generated_output_files",
    "candidate_count",
    "duplicate_count",
    "candidates",
    "invariants",
    "proof_ceiling",
    "public_safe_status",
    "notes_boundary"
  ],
  "properties": {
    "schema_version": { "const": "runtime-case-collector-v0-windows" },
    "collector_version": { "const": "runtime-case-collector-v0-windows" },
    "collector_lane": { "const": "windows" },
    "collector_run_id": { "type": "string", "minLength": 1 },
    "generated_output_files": { "type": "boolean" },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "duplicate_count": { "type": "integer", "minimum": 0 },
    "proof_ceiling": { "const": "RUNTIME_CASE_COLLECTOR_V0_WINDOWS_PRIVATE_CANDIDATE_COLLECTION_ONLY" },
    "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
    "notes_boundary": { "type": "string", "minLength": 1 },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_safe_status",
        "ai_support_mode",
        "ai_decided_disposition",
        "human_review_required",
        "case_closed",
        "append_to_lifetime_ledger",
        "proof_promotion_allowed",
        "public_safe_promotion_allowed",
        "github_issue_mutation_allowed",
        "raw_private_evidence_imported",
        "runtime_candidate_only"
      ],
      "properties": {
        "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
        "ai_support_mode": { "const": "AI_SUPPORT_ONLY" },
        "ai_decided_disposition": { "type": "boolean", "const": false },
        "human_review_required": { "type": "boolean", "const": true },
        "case_closed": { "type": "boolean", "const": false },
        "append_to_lifetime_ledger": { "type": "boolean", "const": false },
        "proof_promotion_allowed": { "type": "boolean", "const": false },
        "public_safe_promotion_allowed": { "type": "boolean", "const": false },
        "github_issue_mutation_allowed": { "type": "boolean", "const": false },
        "raw_private_evidence_imported": { "type": "boolean", "const": false },
        "runtime_candidate_only": { "type": "boolean", "const": true }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "collector_version",
          "collector_lane",
          "collector_run_id",
          "collected_at_utc",
          "candidate_id",
          "candidate_hash",
          "detection_id",
          "detection_family",
          "source_system",
          "source_truth_status",
          "runtime_truth_status",
          "signal_truth_status",
          "proof_ceiling",
          "public_safe_status",
          "case_status",
          "triage_status",
          "disposition_status",
          "ai_support_mode",
          "ai_decided_disposition",
          "human_review_required",
          "deterministic_close_eligible",
          "deterministic_close_blocked",
          "case_closed",
          "append_to_lifetime_ledger",
          "candidate_payload_hash",
          "sanitized_event_fingerprint",
          "source_receipt_refs",
          "blocked_claims",
          "notes_boundary"
        ],
        "properties": {
          "collector_version": { "const": "runtime-case-collector-v0-windows" },
          "collector_lane": { "const": "windows" },
          "collector_run_id": { "type": "string", "minLength": 1 },
          "collected_at_utc": { "type": "string", "minLength": 1 },
          "candidate_id": { "type": "string", "pattern": "^rccv0-win-[0-9a-f]{16}$" },
          "candidate_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "detection_id": { "type": "string", "minLength": 1 },
          "detection_family": { "type": "string", "minLength": 1 },
          "source_system": { "type": "string", "minLength": 1 },
          "source_truth_status": { "type": "string", "minLength": 1 },
          "runtime_truth_status": { "type": "string", "minLength": 1 },
          "signal_truth_status": { "type": "string", "minLength": 1 },
          "proof_ceiling": { "const": "RUNTIME_CASE_COLLECTOR_V0_WINDOWS_PRIVATE_CANDIDATE_COLLECTION_ONLY" },
          "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
          "case_status": { "const": "RUNTIME_CANDIDATE_ONLY" },
          "triage_status": { "const": "HUMAN_REVIEW_REQUIRED" },
          "disposition_status": { "const": "NO_DISPOSITION" },
          "ai_support_mode": { "const": "AI_SUPPORT_ONLY" },
          "ai_decided_disposition": { "type": "boolean", "const": false },
          "human_review_required": { "type": "boolean", "const": true },
          "deterministic_close_eligible": { "type": "boolean", "const": false },
          "deterministic_close_blocked": { "type": "boolean", "const": true },
          "case_closed": { "type": "boolean", "const": false },
          "append_to_lifetime_ledger": { "type": "boolean", "const": false },
          "candidate_payload_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "sanitized_event_fingerprint": { "type": "string", "minLength": 1 },
          "source_receipt_refs": { "type": "array", "minItems": 1 },
          "blocked_claims": { "type": "array", "minItems": 1 },
          "notes_boundary": { "type": "string", "minLength": 1 },
          "observed_time_utc": { "type": "string" }
        }
      }
    }
  }
}
