{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hoxline Schedule Readiness v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "readiness_id",
    "detection_id",
    "runtime_truth_class",
    "public_safe_status",
    "schedule_enabled",
    "active_cron_trigger",
    "emergency_disable_available",
    "continuous_gate_required",
    "repo_variable_required",
    "runner_health",
    "wazuh_health",
    "private_route_health",
    "checkpoint_health",
    "duplicate_suppression_health",
    "dead_letter_health",
    "backpressure_policy",
    "no_new_signal_decision",
    "duplicate_signal_decision",
    "retry_policy",
    "evidence_graph_hash",
    "promotion_hash",
    "claim_authority_decision_hash",
    "readiness_verdict",
    "blocked_enable_reasons",
    "allowed_next_actions",
    "blocked_next_actions",
    "readiness_hash"
  ],
  "properties": {
    "schema_version": { "const": "hoxline-schedule-readiness-v0" },
    "readiness_id": { "type": "string" },
    "detection_id": { "const": "HO-DET-001" },
    "runtime_truth_class": { "const": "PRIVATE_CONTROLLED_RUNTIME_PROOF" },
    "public_safe_status": { "const": "NOT_PUBLIC_SAFE" },
    "schedule_enabled": { "const": false },
    "active_cron_trigger": { "const": false },
    "emergency_disable_available": { "type": "boolean" },
    "continuous_gate_required": { "type": "boolean" },
    "repo_variable_required": { "type": "string" },
    "runner_health": { "type": "object" },
    "wazuh_health": { "type": "object" },
    "private_route_health": { "type": "object" },
    "checkpoint_health": { "type": "object" },
    "duplicate_suppression_health": { "type": "object" },
    "dead_letter_health": { "type": "object" },
    "backpressure_policy": { "type": "object" },
    "no_new_signal_decision": { "type": "object" },
    "duplicate_signal_decision": { "type": "object" },
    "retry_policy": { "type": "object" },
    "evidence_graph_hash": { "type": ["string", "null"] },
    "promotion_hash": { "type": ["string", "null"] },
    "claim_authority_decision_hash": { "type": ["string", "null"] },
    "readiness_verdict": {
      "enum": [
        "READY_FOR_SEPARATE_SCHEDULE_APPROVAL",
        "NOT_READY_BACKPRESSURE_MISSING",
        "NOT_READY_RUNNER_HEALTH_MISSING",
        "NOT_READY_WAZUH_HEALTH_MISSING",
        "NOT_READY_PRIVATE_ROUTE_MISSING",
        "NOT_READY_CLAIM_AUTHORITY_MISSING",
        "NOT_READY_GOVERNANCE_RISK"
      ]
    },
    "blocked_enable_reasons": { "type": "array", "items": { "type": "string" } },
    "allowed_next_actions": { "type": "array", "items": { "type": "string" } },
    "blocked_next_actions": { "type": "array", "items": { "type": "string" } },
    "readiness_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
